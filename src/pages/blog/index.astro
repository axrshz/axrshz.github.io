---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
---

<BaseLayout title="Blog &mdash; Adarsh" description="Notes, essays, and field reports.">
  <section>
    <p class="eyebrow">// writings</p>
    <h1>Blog</h1>
    <p class="lede">Writings on engineering, systems, and things I am working on and learning about.</p>

    <ul class="posts">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`}>
            <span class="date">{fmt(post.data.pubDate)}</span>
            <span class="title">{post.data.title}</span>
            <span class="desc">{post.data.description}</span>
          </a>
        </li>
      ))}
    </ul>

    {posts.length === 0 && (
      <p class="empty">Nothing here yet. Check back soon.</p>
    )}
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.78rem;
    color: var(--muted);
    margin: 3.5rem 0 1rem;
  }
  h1 {
    margin-bottom: 1rem;
  }
  .lede {
    color: var(--muted);
    max-width: 64ch;
    margin-bottom: 3rem;
  }
  .posts {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .posts li + li {
    margin-top: 1.25rem;
  }
  .posts li a {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0.25rem 1.5rem;
    padding: 1.4rem 0;
    border-bottom: none;
  }
  .posts li a:hover {
    border-bottom-color: transparent;
  }
  .date {
    grid-row: 1 / span 2;
    align-self: start;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.78rem;
    color: var(--muted);
    padding-top: 2px;
  }
  .title {
    font-weight: 600;
    letter-spacing: -0.01em;
    font-size: 1.05rem;
  }
  .desc {
    color: var(--muted);
    font-size: 0.95rem;
  }
  .posts li a:hover .title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .empty {
    color: var(--muted);
    padding: 2rem 0;
  }
</style>